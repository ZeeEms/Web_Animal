.buttonVis {
    background-color: white;
    color:black;
    padding: 16px;
    font-size: 16px;
}

.filterContent {
    display: none;
    position: absolute;
    background-color: #ffdcdc;
    min-width: 160px;
    overflow: auto;
}

.filterContent button {
    color: #463930;
    border-color: #463930;
    background-color: #F5F0E6;
    padding: 12px 32px;
    cursor: pointer;
    width: 160px;
    display: block;
}

.show {
    display: block;
}

.card {
    position: relative;
    transform-style: preserve-3d;
    transform-origin: center right;
    transition: all 0.7s;

    width: 280px;
    height: 360px;
    color:white;
    background-color: blue;
}